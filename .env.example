# Local Docker Postgres (docker compose up -d):
DATABASE_URL="postgresql://portfolio:portfolio@localhost:5432/portfolio"
# Vercel Postgres / Neon for production — same variable, no code changes:
# DATABASE_URL="postgresql://<user>:<password>@<host>/<db>?sslmode=require&pgbouncer=true"

# Generate with: pnpm dlx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET=""

# Absolute origin, no trailing slash — used for sitemap.xml/robots.txt URLs.
SITE_URL="http://localhost:3000"

# Encrypts provider connection tokens (GitHub/Vercel PATs) at rest, AES-256-GCM.
# Must decode to exactly 32 bytes. Generate with: openssl rand -base64 32
ENCRYPTION_KEY=""

# Seed script only (pnpm db:seed) — the single v1 admin account.
SEED_ADMIN_EMAIL=""
SEED_ADMIN_PASSWORD=""
SEED_WORKSPACE_SLUG="me"
