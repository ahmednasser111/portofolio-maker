// M0: identity + tenancy. M1: portfolio content (Profile, Projects, Skills,
// Experience, Education, Social Links). Theme/Analytics/Imports/Assets land
// in later milestones. See docs/database-design.md for the full model and
// docs/milestones/ for what deviates from it and why.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MembershipRole {
  OWNER
  ADMIN
  EDITOR
  VIEWER
}

model User {
  id           String   @id
  email        String   @unique
  name         String?
  image        String?
  passwordHash String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  accounts    Account[]
  memberships Membership[]

  createdProfiles       Profile[]       @relation("ProfileCreatedBy")
  updatedProfiles       Profile[]       @relation("ProfileUpdatedBy")
  createdProjects       Project[]       @relation("ProjectCreatedBy")
  updatedProjects       Project[]       @relation("ProjectUpdatedBy")
  createdSkillCats      SkillCategory[] @relation("SkillCategoryCreatedBy")
  updatedSkillCats      SkillCategory[] @relation("SkillCategoryUpdatedBy")
  createdSkills         Skill[]         @relation("SkillCreatedBy")
  updatedSkills         Skill[]         @relation("SkillUpdatedBy")
  createdExperiences    Experience[]    @relation("ExperienceCreatedBy")
  updatedExperiences    Experience[]    @relation("ExperienceUpdatedBy")
  createdEducations     Education[]     @relation("EducationCreatedBy")
  updatedEducations     Education[]     @relation("EducationUpdatedBy")
  createdSocialLinks    SocialLink[]    @relation("SocialLinkCreatedBy")
  updatedSocialLinks    SocialLink[]    @relation("SocialLinkUpdatedBy")
  createdImportSessions ImportSession[] @relation("ImportSessionCreatedBy")

  @@map("users")
}

// Auth.js OAuth account linkage. Unused until an OAuth provider is added
// (v1 login is Credentials-only) — included now per the DDD so it never
// needs a later migration.
model Account {
  id                String  @id
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

// Auth.js email-verification flow. Unused until email/OAuth login exists.
model VerificationToken {
  id         String   @id
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Workspace {
  id            String   @id
  slug          String   @unique
  siteTitle     String?
  isPublished   Boolean  @default(false)
  customDomain  String?  @unique
  activeThemeId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  memberships         Membership[]
  profile             Profile?
  projectCategories   ProjectCategory[]
  projects            Project[]
  skillCategories     SkillCategory[]
  skills              Skill[]
  experiences         Experience[]
  educations          Education[]
  socialLinks         SocialLink[]
  themes              Theme[]              @relation("ThemeWorkspace")
  activeTheme         Theme?               @relation("WorkspaceActiveTheme", fields: [activeThemeId], references: [id], onDelete: Restrict)
  navigationItems     NavigationItem[]
  seoSettings         SeoSetting[]
  contactMessages     ContactMessage[]
  providerConnections ProviderConnection[]
  importSessions      ImportSession[]
  assets              Asset[]

  @@map("workspaces")
}

// Composite natural PK — no surrogate id, no UUIDv7 (see src/lib/db.ts).
model Membership {
  userId      String
  workspaceId String
  role        MembershipRole
  joinedAt    DateTime       @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@id([userId, workspaceId])
  @@index([workspaceId])
  @@map("memberships")
}

// ---------------------------------------------------------------------------
// M1: Portfolio content
// ---------------------------------------------------------------------------

enum AvailabilityStatus {
  AVAILABLE
  UNAVAILABLE
  OPEN_TO_OFFERS
}

enum ProjectStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// Provenance only — GitHub/Resume import pipelines are M3/M4. Every M1
// project is MANUAL; the other values and the externalId/importedAt/
// sourceSnapshot columns below just ensure the schema won't need to change
// when those pipelines land.
enum ContentSource {
  MANUAL
  GITHUB
  RESUME
}

enum ProjectLinkType {
  REPOSITORY
  LIVE_DEMO
  DOCUMENTATION
  OTHER
}

enum SkillLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  FREELANCE
  INTERNSHIP
  VOLUNTEER
}

// Upload validation rules (allowed MIME, size caps) key off kind — enforced
// in the application layer, not the schema (database-design.md §5).
// PROJECT_MEDIA and OTHER are unseeded until ProjectMedia / another upload
// surface lands — same "full enum, partial exercise" convention as
// NavigationPage.CERTIFICATIONS.
enum AssetKind {
  AVATAR
  PROJECT_MEDIA
  RESUME
  OG_IMAGE
  OTHER
}

// One row per uploaded file (database-design.md §4.7): avatar, resume PDF,
// OG image today; project media once ProjectMedia lands. Soft delete only —
// the blob itself is garbage-collected after the grace period by a future
// job, never deleted synchronously with the row.
model Asset {
  id          String    @id
  workspaceId String
  kind        AssetKind
  url         String
  filename    String
  mimeType    String
  sizeBytes   Int
  checksum    String
  width       Int?
  height      Int?
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  // Inverse sides of the named FK relations below — Prisma requires them
  // even though each is effectively 0..1 in practice (one asset backs one
  // profile avatar / resume, one SEO row's OG image, one import session).
  profileAvatarFor       Profile[]       @relation("ProfileAvatarAsset")
  profileResumeFor       Profile[]       @relation("ProfilePublicResumeAsset")
  seoOgImageFor          SeoSetting[]    @relation("SeoOgImageAsset")
  importSessionSourceFor ImportSession[] @relation("ImportSessionSourceAsset")

  @@index([workspaceId, kind])
  @@map("assets")
}

// 1:1 with Workspace. avatarAssetId/publicResumeAssetId upgraded from plain
// URL strings to Asset FKs in M4, once the Asset table + blob upload
// pipeline existed to back them (database-design.md §4.2, §4.7).
model Profile {
  id                  String              @id
  workspaceId         String              @unique
  displayName         String
  position            String?
  headline            String?
  bio                 Json?
  avatarAssetId       String?
  location            String?
  availability        AvailabilityStatus?
  email               String?
  phone               String?
  heroCtaLabel        String?
  heroCtaUrl          String?
  publicResumeAssetId String?
  createdById         String?
  updatedById         String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  workspace         Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy         User?     @relation("ProfileCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy         User?     @relation("ProfileUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  avatarAsset       Asset?    @relation("ProfileAvatarAsset", fields: [avatarAssetId], references: [id], onDelete: SetNull)
  publicResumeAsset Asset?    @relation("ProfilePublicResumeAsset", fields: [publicResumeAssetId], references: [id], onDelete: SetNull)

  @@map("profiles")
}

// New entity (not in the original DDD) mirroring SkillCategory — categories
// as rows, not a free-text column, per the DDD's own normalization rule
// (§1). Deleting a category SetNulls Project.categoryId rather than
// cascading, unlike SkillCategory→Skill: a project is an independent,
// valuable entity; a skill is a meaningless leaf outside its category.
// Configuration-like (same rule-of-thumb as NavigationItem) — no soft
// delete, no audit columns.
model ProjectCategory {
  id          String   @id
  workspaceId String
  name        String
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  projects  Project[]

  @@unique([workspaceId, name])
  @@map("project_categories")
}

model Project {
  id          String        @id
  workspaceId String
  categoryId  String?
  title       String
  // Partial-unique (workspaceId, slug) WHERE deleted_at IS NULL — hand-edited
  // into the migration SQL; see database-design.md §4.3 / §14.3. Do not
  // regenerate this migration from the schema without re-applying that edit.
  slug        String
  summary     String?
  description Json?
  status      ProjectStatus @default(DRAFT)
  featured    Boolean       @default(false)
  sortOrder   Int           @default(0)
  startDate   DateTime?
  endDate     DateTime?
  tags        String[]

  source         ContentSource @default(MANUAL)
  externalId     String?
  importedAt     DateTime?
  sourceSnapshot Json?

  createdById String?
  updatedById String?
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workspace Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  category  ProjectCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdBy User?            @relation("ProjectCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User?            @relation("ProjectUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  links     ProjectLink[]

  @@unique([workspaceId, slug])
  @@index([workspaceId, status, sortOrder])
  @@index([workspaceId, source, externalId])
  @@map("projects")
}

model ProjectLink {
  id          String          @id
  workspaceId String
  projectId   String
  type        ProjectLinkType
  label       String?
  url         String
  sortOrder   Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, sortOrder])
  @@map("project_links")
}

model SkillCategory {
  id          String    @id
  workspaceId String
  name        String
  sortOrder   Int       @default(0)
  createdById String?
  updatedById String?
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy User?     @relation("SkillCategoryCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User?     @relation("SkillCategoryUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  skills    Skill[]

  // Partial-unique (workspaceId, name) WHERE deleted_at IS NULL — hand-edited,
  // same convention as projects.slug.
  @@unique([workspaceId, name])
  @@index([workspaceId, sortOrder])
  @@map("skill_categories")
}

model Skill {
  id          String      @id
  workspaceId String
  categoryId  String
  name        String
  level       SkillLevel?
  iconKey     String?
  visible     Boolean     @default(true)
  sortOrder   Int         @default(0)
  createdById String?
  updatedById String?
  deletedAt   DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  source         ContentSource @default(MANUAL)
  externalId     String?
  importedAt     DateTime?
  sourceSnapshot Json?

  workspace Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  category  SkillCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdBy User?         @relation("SkillCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User?         @relation("SkillUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  // Partial-unique (workspaceId, name) WHERE deleted_at IS NULL — hand-edited,
  // same convention as projects.slug. Doubles as the resume-import dedupe
  // anchor (M4).
  @@unique([workspaceId, name])
  @@index([categoryId, sortOrder])
  @@index([workspaceId, source, externalId])
  @@map("skills")
}

model Experience {
  id             String          @id
  workspaceId    String
  company        String
  role           String
  location       String?
  employmentType EmploymentType?
  startDate      DateTime
  endDate        DateTime?
  highlights     Json?
  description    String?
  visible        Boolean         @default(true)
  sortOrder      Int             @default(0)
  createdById    String?
  updatedById    String?
  deletedAt      DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  source         ContentSource @default(MANUAL)
  externalId     String?
  importedAt     DateTime?
  sourceSnapshot Json?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy User?     @relation("ExperienceCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User?     @relation("ExperienceUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([workspaceId, sortOrder])
  @@index([workspaceId, source, externalId])
  @@map("experiences")
}

model Education {
  id          String    @id
  workspaceId String
  institution String
  degree      String?
  field       String?
  startDate   DateTime?
  endDate     DateTime?
  description String?
  visible     Boolean   @default(true)
  sortOrder   Int       @default(0)
  createdById String?
  updatedById String?
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  source         ContentSource @default(MANUAL)
  externalId     String?
  importedAt     DateTime?
  sourceSnapshot Json?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy User?     @relation("EducationCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User?     @relation("EducationUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([workspaceId, sortOrder])
  @@index([workspaceId, source, externalId])
  @@map("educations")
}

model SocialLink {
  id          String    @id
  workspaceId String
  platform    String
  iconKey     String?
  url         String
  sortOrder   Int       @default(0)
  visible     Boolean   @default(true)
  createdById String?
  updatedById String?
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy User?     @relation("SocialLinkCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User?     @relation("SocialLinkUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([workspaceId, sortOrder])
  @@map("social_links")
}

// ---------------------------------------------------------------------------
// M2: Presentation control (Theme, Navigation, SEO, Contact)
// ---------------------------------------------------------------------------

// Closed by code — each value is a built public route. CERTIFICATIONS is
// reserved (matches database-design.md §5) but not seeded into
// NavigationItem yet since that module doesn't exist (cut from M1).
enum NavigationPage {
  HOME
  ABOUT
  SKILLS
  EXPERIENCE
  EDUCATION
  CERTIFICATIONS
  PROJECTS
  CONTACT
  RESUME
}

// workspaceId NULL ⇒ global preset (database-design.md §4.6, §11). Activating
// a preset clones it into a workspace-owned row (basePresetId records the
// lineage) rather than referencing it directly — preset updates never mutate
// live sites. CHECK isPreset=true ⇒ workspaceId IS NULL is hand-edited into
// the migration (no native Prisma support for CHECK constraints).
model Theme {
  id            String   @id
  workspaceId   String?
  name          String
  tokens        Json
  schemaVersion Int      @default(1)
  isPreset      Boolean  @default(false)
  basePresetId  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workspace           Workspace?  @relation("ThemeWorkspace", fields: [workspaceId], references: [id], onDelete: Cascade)
  basePreset          Theme?      @relation("ThemeLineage", fields: [basePresetId], references: [id], onDelete: SetNull)
  clonedFrom          Theme[]     @relation("ThemeLineage")
  activeForWorkspaces Workspace[] @relation("WorkspaceActiveTheme")

  @@index([workspaceId])
  @@map("themes")
}

model NavigationItem {
  id          String         @id
  workspaceId String
  page        NavigationPage
  customLabel String?
  sortOrder   Int            @default(0)
  enabled     Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, page])
  @@map("navigation_items")
}

// page NULL ⇒ workspace-default row. ogImageAssetId upgraded from a plain
// string to an Asset FK in M4, same as Profile.avatarAssetId/publicResumeAssetId.
// Unique (workspaceId, page) NULLS NOT DISTINCT — hand-edited (PG15+), same
// convention as the M1 partial-unique indexes.
model SeoSetting {
  id             String          @id
  workspaceId    String
  page           NavigationPage?
  title          String?
  description    String?
  ogImageAssetId String?
  noindex        Boolean         @default(false)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  ogImageAsset Asset?    @relation("SeoOgImageAsset", fields: [ogImageAssetId], references: [id], onDelete: SetNull)

  @@unique([workspaceId, page])
  @@map("seo_settings")
}

// Hard delete, no soft delete, no audit columns — visitor-created, per
// database-design.md §1/§4.5.
model ContactMessage {
  id          String    @id
  workspaceId String
  senderName  String
  senderEmail String
  body        String
  readAt      DateTime?
  createdAt   DateTime  @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt(sort: Desc)])
  @@map("contact_messages")
}

// ---------------------------------------------------------------------------
// M3: Provider framework (GitHub import + Vercel linking)
// ---------------------------------------------------------------------------

// RESUME (M4) has no connection step (plain file upload), so it only ever
// appears on ImportSession.provider, never on a ProviderConnection row.
// Application-level rule, not schema-enforced.
enum ProviderType {
  GITHUB
  VERCEL
  RESUME
}

enum ConnectionStatus {
  ACTIVE
  EXPIRED
  REVOKED
  ERROR
}

// PROCESSING is used starting M4 (async LLM extraction step for resume
// sessions — GitHub sessions still skip straight PENDING -> REVIEWING).
// ROLLED_BACK remains reserved — undo is not in scope for any milestone yet.
enum ImportSessionStatus {
  PENDING
  PROCESSING
  REVIEWING
  COMMITTED
  DISCARDED
  FAILED
  ROLLED_BACK
}

enum ImportItemStatus {
  PENDING
  ACCEPTED
  EDITED
  REJECTED
  SKIPPED_DUPLICATE
  COMMITTED
}

// EXPERIENCE, EDUCATION, SKILL, PROFILE_SUMMARY land in M4 (resume import
// fans out to all of them). CERTIFICATION stays reserved/unseeded — there is
// no Certification model yet (cut from M1, not revived for M4 either); the
// resume LLM prompt does not emit it.
enum ImportTargetType {
  PROJECT
  EXPERIENCE
  EDUCATION
  SKILL
  CERTIFICATION
  PROFILE_SUMMARY
}

// One row per provider per workspace. Hard delete on disconnect (token must
// not linger, even soft-deleted) — see database-design.md §1. encryptedToken
// is base64 AES-256-GCM ciphertext+IV+authTag; keyVersion records which
// ENCRYPTION_KEY encrypted it so key rotation is a background re-encrypt,
// not a crisis (DDD §14.7).
model ProviderConnection {
  id             String           @id
  workspaceId    String
  provider       ProviderType
  encryptedToken String
  keyVersion     Int              @default(1)
  accountMeta    Json?
  status         ConnectionStatus @default(ACTIVE)
  connectedAt    DateTime         @default(now())
  lastCheckedAt  DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, provider])
  @@map("provider_connections")
}

// One row per import run (a GitHub repo-selection batch, or one resume
// upload). sourceAssetId (resume PDF pointer) is set for RESUME-provider
// sessions only; GitHub sessions leave it null — no rawPayload file either.
model ImportSession {
  id                   String              @id
  workspaceId          String
  provider             ProviderType
  status               ImportSessionStatus @default(PENDING)
  sourceAssetId        String?
  rawPayload           Json?
  payloadSchemaVersion Int?
  error                String?
  committedAt          DateTime?
  createdById          String?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy   User?        @relation("ImportSessionCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  sourceAsset Asset?       @relation("ImportSessionSourceAsset", fields: [sourceAssetId], references: [id], onDelete: SetNull)
  items       ImportItem[]

  @@index([workspaceId, provider, status])
  @@map("import_sessions")
}

// workspaceId is redundant with sessionId->workspaceId but kept per the DDD's
// deliberate redundant-scoping rule (§1) so every query filters locally
// without a join. duplicateOfId / createdEntityType+createdEntityId are
// loose polymorphic pointers, no FK — see database-design.md §9.6.
model ImportItem {
  id                String           @id
  sessionId         String
  workspaceId       String
  targetType        ImportTargetType
  data              Json
  dataSchemaVersion Int              @default(1)
  status            ImportItemStatus @default(PENDING)
  duplicateOfId     String?
  createdEntityType String?
  createdEntityId   String?
  externalId        String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  session ImportSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([workspaceId, targetType, externalId])
  @@map("import_items")
}
